#include <stdio.h>
#include <stdlib.h>
#include <cuda_runtime.h>
#include <math.h>

#define N 1048576
#define BLOCK_SIZE 256

__global__ void bitonic_sort_step(int* arr, int step, int dir) {
    __shared__ int s_data[BLOCK_SIZE * 2];
    int tid = threadIdx.x;
    int global_id = blockIdx.x * blockDim.x * 2 + tid;
    
    if (global_id + blockDim.x >= step * 2) return;
    
    s_data[tid] = arr[global_id];
    s_data[tid + blockDim.x] = arr[global_id + blockDim.x];
    __syncthreads();
    
    for (int i = 0; i < step; i++) {
        if ((global_id / (2 * i)) % 2 == dir) {
            if (tid < blockDim.x && s_data[tid] > s_data[tid + blockDim.x]) {
                int temp = s_data[tid];
                s_data[tid] = s_data[tid + blockDim.x];
                s_data[tid + blockDim.x] = temp;
            }
        } else {
            if (tid < blockDim.x && s_data[tid] < s_data[tid + blockDim.x]) {
                int temp = s_data[tid];
                s_data[tid] = s_data[tid + blockDim.x];
                s_data[tid + blockDim.x] = temp;
            }
        }
        __syncthreads();
    }
    
    arr[global_id] = s_data[tid];
    arr[global_id + blockDim.x] = s_data[tid + blockDim.x];
}

void bitonic_sort_cuda(int* h_arr, int n) {
    int* d_arr;
    cudaMalloc(&d_arr, n * sizeof(int));
    cudaMemcpy(d_arr, h_arr, n * sizeof(int), cudaMemcpyHostToDevice);
    
    int num_blocks = n / (BLOCK_SIZE * 2);
    for (int step = 1; step < n; step <<= 1) {
        for (int dir = 0; dir <= 1; dir++) {
            bitonic_sort_step<<<num_blocks, BLOCK_SIZE>>>(d_arr, step, dir);
            cudaDeviceSynchronize();
        }
    }
    
    cudaMemcpy(h_arr, d_arr, n * sizeof(int), cudaMemcpyDeviceToHost);
    cudaFree(d_arr);
}

int main() {
    int* arr = (int*)malloc(N * sizeof(int));
    srand(time(NULL));
    for (int i = 0; i < N; i++) arr[i] = rand() % 1000000;
    
    cudaEvent_t start, stop;
    cudaEventCreate(&start);
    cudaEventCreate(&stop);
    cudaEventRecord(start);
    
    bitonic_sort_cuda(arr, N);
    
    cudaEventRecord(stop);
    cudaEventSynchronize(stop);
    
    float time_ms;
    cudaEventElapsedTime(&time_ms, start, stop);
    
    printf("CUDA bitonic sort time = %.6f sec\n", time_ms / 1000.0);
    free(arr);
    return 0;
}
