#include <stdio.h>
#include <stdlib.h>
#include <cuda_runtime.h>
#include <curand_kernel.h>
#include <math.h>

#define N 100000000
#define BLOCK_SIZE 256

__device__ double f(double x, double y) {
    return x*x + 2*y;
}

__device__ int in_region(double x, double y) {
    double y_low = x*x - 1;
    double y_high = x + 1;
    return (y >= y_low && y <= y_high);
}

__global__ void monte_carlo_kernel(double* d_sum_f, int n,
                                    double x_min, double x_max,
                                    double y_min, double y_max,
                                    unsigned long long seed) {
    int tid = blockIdx.x * blockDim.x + threadIdx.x;
    if (tid >= n) return;
    
    curandState state;
    curand_init(seed + tid, tid, 0, &state);
    
    double local_sum = 0.0;
    int points_per_thread = n / (gridDim.x * blockDim.x);
    
    for (int i = 0; i < points_per_thread; i++) {
        double x = x_min + curand_uniform_double(&state) * (x_max - x_min);
        double y = y_min + curand_uniform_double(&state) * (y_max - y_min);
        if (in_region(x, y)) {
            local_sum += f(x, y);
        }
    }
    
    atomicAdd(d_sum_f, local_sum);
}

int main() {
    double x_min = -1.0, x_max = 2.0;
    double y_min = -2.0, y_max = 3.0;
    double area = (x_max - x_min) * (y_max - y_min);
    
    int num_blocks = (N + BLOCK_SIZE - 1) / BLOCK_SIZE;
    if (num_blocks > 1024) num_blocks = 1024;
    
    double *d_sum_f;
    double h_sum_f = 0.0;
    
    cudaMalloc(&d_sum_f, sizeof(double));
    cudaMemcpy(d_sum_f, &h_sum_f, sizeof(double), cudaMemcpyHostToDevice);
    
    cudaEvent_t start, stop;
    cudaEventCreate(&start);
    cudaEventCreate(&stop);
    
    cudaEventRecord(start);
    
    monte_carlo_kernel<<<num_blocks, BLOCK_SIZE>>>(d_sum_f, N, x_min, x_max, y_min, y_max, 12345);
    
    cudaEventRecord(stop);
    cudaDeviceSynchronize();
    
    cudaMemcpy(&h_sum_f, d_sum_f, sizeof(double), cudaMemcpyDeviceToHost);
    
    float time_ms;
    cudaEventElapsedTime(&time_ms, start, stop);
    double time = time_ms / 1000.0;
    
    double integral = area * h_sum_f / N;
    double exact = 9.0;
    double error = fabs(integral - exact);
    
    printf("Number of trials: %d\n", N);
    printf("Sum of f(x,y) in region: %.6f\n", h_sum_f);
    printf("Area: %.6f\n", area);
    printf("Integral = %.6f (exact = 9)\n", integral);
    printf("Error = %.6e (%.2f%%)\n", error, error / exact * 100);
    printf("CUDA time = %.6f sec\n", time);
    
    cudaFree(d_sum_f);
    return 0;
}
